<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link rel="stylesheet" href="/login.css">
</head>
<body>
  <div id="wholeLogin">
    <div id="loginBlock">
      <p class="greeting">Welcome</p>
      <form action="/confirmSign" method="POST" class="formContainer">
        <%if(typeof error!='undefined'){%>
          <ul class="errorBlock">
            <%error.forEach(err=>{%>
              <li><%=err%></li>
            <%})%>
          </ul>
        <%}%>
        <div class="toggleAndDisplay">
          <button type="button" class="toggle" onclick="hostShift()">
            <div class="insideToggle">
            </div>
          </button>
          <div class="displayToggle">User</div>
        </div> 
        <input type="hidden" class="hiddenInput" name="userType" value="User">
        <input class="userInput" type="text" placeholder="Enter your name" name="firstName">
        <input class="userInput" type="text" placeholder="Enter your sur name" name="surName">
        <input class="userInput" type="email" placeholder="Enter the email" name="email">
        <input class="userInput" type="password" placeholder="Enter the password" name="password">
        <input class="userInput" type="password" placeholder="Enter the password" name="confirmPassword">
        <div>
          <button type="submit" class="loginButtons">Login</button>
        </div>
      </div>
    </div>
  </div>
  <script src="/loginScript.js"></script>
</body>
</html>